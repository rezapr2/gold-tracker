# Root env shared by all backend services (docker-compose reads this as env_file).
# Copy to .env and fill in. Service-internal hosts (mongo/redis/rabbitmq) are set
# by docker-compose; the values here are secrets + provider config.

# --- Datastores (prod/vm compose) ---
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=change-me
REDIS_PASSWORD=change-me

# --- Message bus (compose sets RABBITMQ_URL=amqp://rabbitmq:5672 internally) ---
# RABBITMQ_URL=amqp://localhost:5672

# --- Price providers (fetcher-metals) ---
GOLD_API_COM_URL=https://api.gold-api.com
GOLDAPI_KEY=
METALS_DEV_KEY=
TWELVE_DATA_KEY=
ALPHA_VANTAGE_KEY=

# --- Iranian source (fetcher-estjt) ---
ESTJT_URL=https://www.estjt.ir/tv/

# --- Telegram bots (telegram-bot) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_SILVER_BOT_TOKEN=
TELEGRAM_SILVER_CHANNEL_ID=
TELEGRAM_SEND_CHARTS=true
TELEGRAM_COMMANDS_ENABLED=false
QUICKCHART_URL=https://quickchart.io

# --- Auth / admin (web-api) ---
JWT_SECRET=please-change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@goldtracker.com
ADMIN_PASSWORD=Admin@123456
ADMIN_PASSWORD_HASH=

# --- Behaviour ---
PRICE_ALERT_THRESHOLD=1.5
PRICE_FETCH_INTERVAL=*/1 * * * *

# --- URLs ---
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001
