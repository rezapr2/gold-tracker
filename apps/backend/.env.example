# Application
NODE_ENV=development
PORT=3001
APP_SECRET=change-this-super-secret-key-in-production

# MongoDB
MONGODB_URI=mongodb://localhost:27017/gold-tracker

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-jwt-secret-key
JWT_EXPIRES_IN=7d

# Admin Credentials
ADMIN_EMAIL=admin@goldtracker.com
ADMIN_PASSWORD=Admin@123456

# Gold Price APIs (add your keys)
GOLDAPI_KEY=your_goldapi_key_here
METALS_DEV_KEY=your_metals_dev_key_here
TWELVE_DATA_KEY=your_twelve_data_key_here
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Telegram — Gold bot
TELEGRAM_BOT_TOKEN=your_gold_bot_token_here
TELEGRAM_CHANNEL_ID=@your_gold_channel_id

# Telegram — Silver bot (separate bot + channel)
TELEGRAM_SILVER_BOT_TOKEN=your_silver_bot_token_here
TELEGRAM_SILVER_CHANNEL_ID=@your_silver_channel_id

# Set to false to send text-only updates (no chart image)
TELEGRAM_SEND_CHARTS=true
# Enable interactive commands (/gold, /silver, /ratio) via long-polling.
# Keep false unless exactly one backend instance runs per bot token.
TELEGRAM_COMMANDS_ENABLED=false

# Chart rendering (QuickChart-compatible endpoint; self-host for private rendering)
QUICKCHART_URL=https://quickchart.io

# Scheduler
PRICE_FETCH_INTERVAL=*/1 * * * *
TELEGRAM_PUBLISH_INTERVAL=*/30 * * * *
CLEANUP_INTERVAL=0 2 * * *

# Alert Thresholds
PRICE_ALERT_THRESHOLD=1.5

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
